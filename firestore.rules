rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    function orgId() {
      return request.auth.token.orgId;
    }

    function hasOrgId() {
      return isSignedIn() && (orgId() is string) && (orgId().size() > 0);
    }

    function isSameOrg(data) {
      return hasOrgId()
        && (data.orgId is string)
        && data.orgId == orgId();
    }

    // ----------------------------
    // USERS (read-only from client)
    // ----------------------------
    match /users/{uid} {

      allow read: if
        isSuperAdmin()
        || (isSignedIn() && request.auth.uid == uid)
        || (isAdmin()
            && hasOrgId()
            && (resource.data.orgId is string)
            && resource.data.orgId == orgId()
        );

      allow create, update, delete: if false;
    }

    // ----------------------------
    // BINS (multi-tenant)
    // TechBin SuperAdmin creates/provisions bins
    // Sub-org Admins can edit only location/status/capacity
    // ----------------------------
    match /bins/{binId} {

      // READ:
      // - SuperAdmin can read all
      // - Any signed-in user can read only bins in their org
      allow read: if
        isSuperAdmin()
        || (isSameOrg(resource.data));

      // CREATE:
      // - ONLY SuperAdmin (TechBin) can create/provision bins
      allow create: if isSuperAdmin();

      // UPDATE:
      // - SuperAdmin can update anything
      // - Org Admin can update ONLY specific fields for bins in their org
      allow update: if
        isSuperAdmin()
        || (
          isAdmin()
          && isSameOrg(resource.data)
          // orgId and binCode must not change
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.binCode == resource.data.binCode
          // only allow these fields to change
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "location",
            "status",
            "capacityLiters",
            "updatedAt",
            "updatedBy"
          ])
        );

      // DELETE:
      // - ONLY SuperAdmin
      allow delete: if isSuperAdmin();
    }

    // ----------------------------
    // TELEMETRY
    // Read restricted by org
    // Writes: allow Admins to create mock telemetry (dev/testing)
    // ----------------------------
    match /telemetry/{docId} {

      // READ:
      // - SuperAdmin reads all
      // - Others read only their org telemetry
      allow read: if
        isSuperAdmin()
        || (hasOrgId()
            && (resource.data.orgId is string)
            && resource.data.orgId == orgId()
        );

      // CREATE (for mock/testing):
      // - SuperAdmin can create for any org
      // - Org Admin can create only for their org
      allow create: if
        isSuperAdmin()
        || (isAdmin()
            && hasOrgId()
            && (request.resource.data.orgId is string)
            && request.resource.data.orgId == orgId()
        );

      // no client updates/deletes of telemetry
      allow update, delete: if false;
    }

    // ----------------------------
    // SETTINGS (per-user preferences)
    // ----------------------------
    match /settings/{uid} {

      // User can read only their own settings doc.
      allow read: if isSignedIn() && request.auth.uid == uid;

      // User creates their own settings doc. orgId must match token org.
      allow create: if
        isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && hasOrgId()
        && (request.resource.data.orgId is string)
        && request.resource.data.orgId == orgId();

      // User updates only their own doc, while preserving uid/orgId binding.
      allow update: if
        isSignedIn()
        && request.auth.uid == uid
        && (resource.data.uid is string)
        && resource.data.uid == request.auth.uid
        && (resource.data.orgId is string)
        && resource.data.orgId == orgId()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.orgId == resource.data.orgId;

      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
